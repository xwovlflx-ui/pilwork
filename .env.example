# PostgreSQL
DATABASE_URL=""
POSTGRES_USER="change-me"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="change-me"

# NestJS API
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"
JWT_PRIVATE_KEY_PATH="apps/api/keys/dev-private.pem"
JWT_PUBLIC_KEY_PATH="apps/api/keys/dev-public.pem"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_DAYS="30"
COOKIE_SECURE="false"

# Seed only. Never reuse these values in production.
SEED_PASSWORD="change-me-local-seed-password"

# Next.js client
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_AUTH_MODE="database"
